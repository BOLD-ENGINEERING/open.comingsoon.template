#!/usr/bin/env bash

set -euo pipefail

declare -A COMMANDS=(
    ["dev"]="vite"
    ["build"]="run-p type-check \"build-only {@}\" --"
    ["preview"]="vite preview"
    ["build-only"]="vite build"
    ["type-check"]="vue-tsc --build"
    ["lint:oxlint"]="oxlint . --fix -D correctness --ignore-path .gitignore"
    ["lint:eslint"]="eslint . --fix"
    ["lint"]="run-s lint:*"
    ["format"]="prettier --write src/"
)

declare -A COMMAND_DESCRIPTIONS=(
    ["dev"]="Start the local Vite development server"
    ["build"]="Run type checking and build the production bundle"
    ["preview"]="Preview the built production output locally"
    ["build-only"]="Build the production bundle without type checking"
    ["type-check"]="Run Vue type checking"
    ["lint:oxlint"]="Lint the repo using oxlint"
    ["lint:eslint"]="Lint the repo using ESLint"
    ["lint"]="Run both lint tasks"
    ["format"]="Format source files with Prettier"
)

COMMAND_LIST=(dev build preview build-only type-check lint:oxlint lint:eslint lint format)

show_help() {
    echo "oct - Open.comingsoon Template command helper"
    echo ""
    echo "Usage: bash oct <command> [options]"
    echo ""
    echo "Local commands (from package.json):"
    for cmd in "${!COMMANDS[@]}"; do
        echo "  $cmd"
    done
    echo ""
    echo "Docker commands:"
    echo "  docker dev        - Start development container with hot reload"
    echo "  docker web        - Start production container"
    echo "  docker build      - Build Docker image"
    echo ""
    echo "Utility commands:"
    echo "  doctor            - Check system dependencies"
    echo "  list              - List available npm scripts"
    echo "  help              - Show this help message"
    echo ""
    echo "Examples:"
    echo "  bash oct dev                  # Start development server locally"
    echo "  bash oct docker dev           # Start development container"
    echo "  bash oct docker web           # Start production container"
    echo "  bash oct doctor               # Check dependencies"
}

list_scripts() {
    echo "Available scripts:"
    for cmd in "${COMMAND_LIST[@]}"; do
        echo "  $cmd"
        if [ -n "${COMMAND_DESCRIPTIONS[$cmd]:-}" ]; then
            echo "    ${COMMAND_DESCRIPTIONS[$cmd]}"
        fi
        echo "    Example: bash oct $cmd"
        echo ""
    done
}

check_dependencies() {
    echo "Checking system dependencies..."

    echo "Checking Node.js"
    if command -v node &> /dev/null; then
        NODE_VERSION=$(node --version)
        echo "OK Node.js: $NODE_VERSION"
    else
        echo "MISSING Node.js: Not found"
        echo "  Please install Node.js >= 22.22.0"
    fi
    
    echo "Checking Bun"
    if command -v bun &> /dev/null; then
        BUN_VERSION=$(bun --version)
        echo "OK Bun: $BUN_VERSION"
    else
        echo "MISSING Bun: Not found"
        echo "  Please install Bun (https://bun.sh)"
    fi
    
    echo "Checking Docker"
    if command -v docker &> /dev/null; then
        DOCKER_VERSION=$(docker --version)
        echo "OK Docker: $DOCKER_VERSION"
    else
        echo "MISSING Docker: Not found"
        echo "  Please install Docker (https://docker.com)"
    fi
    
    if [ -f "package.json" ]; then
        echo "OK package.json: Found"
    else
        echo "MISSING package.json: Not found in current directory"
    fi
    
    echo ""
    echo "Dependency check complete."
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND="$1"
shift || true

case "$COMMAND" in
    help)
        show_help
        ;;
    list)
        list_scripts
        ;;
    doctor)
        check_dependencies
        ;;
    docker)
        DOCKER_SUBCOMMAND="$1"
        shift || true
        
        case "$DOCKER_SUBCOMMAND" in
            dev)
                docker-compose up dev "$@"
                ;;
            web)
                docker-compose up web "$@"
                ;;
            build)
                docker build -t comingsoon . "$@"
                ;;
            *)
                echo "Error: Unknown Docker subcommand '$DOCKER_SUBCOMMAND'"
                echo ""
                echo "Available Docker subcommands:"
                echo "  dev     - Start development container with hot reload"
                echo "  web     - Start production container"
                echo "  build   - Build Docker image"
                exit 1
                ;;
        esac
        ;;
    *)
        if [[ -n "${COMMANDS[$COMMAND]:-}" ]]; then
            bun run --no-env-file "$COMMAND" "$@"
        else
            echo "Error: Unknown command '$COMMAND'"
            echo ""
            show_help
            exit 1
        fi
        ;;
esac